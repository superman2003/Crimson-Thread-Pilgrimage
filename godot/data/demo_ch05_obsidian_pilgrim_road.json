  "npcs": [
    {
      "id": "npc_obsidian_guide",
      "name": "黑曜引路人",
      "position": [
        320,
        500
      ],
      "role": "route_hint",
      "dialogue": [
        "这里的路只给还会违抗命令的人走；太听话的人会被铺成路面。",
        "灯亮时穿门，灯灭时停下；别把自己的一半留在黑曜石里。",
        "巡礼军不会说话，但他们会执行你不想听见的命令。"
      ],
      "identity": "黑曜哨站的匿名向导，可能是未完全编队的前代巡礼者。",
      "motive": "想让主角保持违抗能力。",
      "help": "解释影门灯亮/灯灭规则；提示巡礼军是命令执行体。"
    },
    {
      "id": "npc_blind_bell_knight",
      "name": "盲钟骑士",
      "position": [
        1360,
        570
      ],
      "role": "combat_mark_witness",
      "dialogue": [
        "我失败过，所以我听不见王冠命令的一小半；那一小半每天都在疼。",
        "如果你选择重鸣，我会再次成为军队；如果你看见我举枪，别犹豫。",
        "如果你选择断冠，记得先告诉我们为什么死；沉默里死太久，会忘记理由。"
      ],
      "identity": "失败的前代巡礼者，成为巡礼军后仍保留少量自我。",
      "motive": "想知道主角会恢复秩序，还是释放被秩序吞掉的人。",
      "help": "关键证词；解释重鸣代价；提供终章道德压力。"
    },
    {
      "id": "npc_lantern_sister",
      "name": "灯影修女",
      "position": [
        3680,
        460
      ],
      "role": "ability_teacher",
      "dialogue": [
        "灯影相位不是隐身，是向命令请半秒假；半秒够你活，也够你选择。",
        "黑曜影门会吃能量，别空着心穿过去，空心的人最容易被命令填满。",
        "终章有一扇门只认沉默军令，但它也会认出拒绝命令的人。"
      ],
      "identity": "影门回廊前的修女，守着灯影相位仪式。",
      "motive": "想把短暂拒令的技巧传给主角。",
      "help": "教授灯影相位；说明影门耗能；提示终章沉默军令门。"
    },
    {
      "id": "npc_deserter_flagbearer",
      "name": "逃旗手",
      "position": [
        11600,
        500
      ],
      "role": "sidequest_moral_choice",
      "dialogue": [
        "我偷了一面不会响的旗，结果它每天晚上命令我回队；旗比人更会认路。",
        "帮我烧掉三面复活旗，我把军令碎片给你；别问旗里的名字会不会疼。",
        "统帅不是坏人，他只是从没被允许停下；一直前进也能变成一种囚禁。"
      ],
      "identity": "携带复活旗逃离队列的旗手，仍被旗帜夜间召回。",
      "motive": "想烧掉复活旗，让自己和队友不再被无限召回。",
      "help": "支线道德选择；烧旗后给军令碎片；解释统帅不是纯粹反派。"
    }
  ],
