  "npcs": [
    {
      "id": "npc_old_gardener",
      "name": "老园丁弦伯",
      "position": [
        320,
        500
      ],
      "role": "main_witness",
      "dialogue": [
        "书库的封面，是从我们这里剪走的活皮；他们叫它档案，我们叫它伤口。",
        "藤蔓先颤，再动；急着跳的人，会被温室记住很久。",
        "六枚印记曾经有名字，后来只剩用途；用途最会吃掉名字。"
      ],
      "identity": "温室前厅的老园丁，曾修剪活封面和守门者根系。",
      "motive": "想让主角知道温室不是花园，而是六位守门者的病房。",
      "help": "说明藤蔓预兆；交代书库活封面来源；点明印记曾有名字。"
    },
    {
      "id": "npc_broken_singer",
      "name": "断弦歌者",
      "position": [
        1360,
        570
      ],
      "role": "keeper_truth",
      "dialogue": [
        "我唱歌不是为了美，是为了让裂缝睡着；美只是没人死时顺手发生的事。",
        "你拿走印记，黑曜巡礼军就会听见你；他们听不见自己，只听得见命令。",
        "若终章让钟重鸣，请记得给我们一个不用继续守门的早晨。"
      ],
      "identity": "第四位守门者残留人格，歌声维持温室上方裂缝沉睡。",
      "motive": "不想再被当作材料，但仍害怕主角拿走印记后裂缝醒来。",
      "help": "关键证词；解释守门者牺牲；给出终章重鸣与真结局伦理提示。"
    },
    {
      "id": "npc_beeswax_vendor",
      "name": "蜂蜡商人蜜岚",
      "position": [
        3680,
        460
      ],
      "role": "vendor_sidequest",
      "dialogue": [
        "花粉过滤器便宜，死在花粉里很贵；我这里不赊账，也不赊命。",
        "蜂巢里有一枚盐页，但我不建议你用脸去拿，脸通常不是战斗标记。",
        "黑曜路上不卖东西，那里的人只收沉默；你最好在我这儿学会吝啬。"
      ],
      "identity": "蜂蜡小屋商人，靠收集花粉过滤器、盐页和蜡封护符生存。",
      "motive": "想赚钱，也想把温室里还能被带走的证据交给真正会用的人。",
      "help": "出售花粉过滤器；提示蜂巢盐页；预告黑曜巡礼道资源稀缺。"
    },
    {
      "id": "npc_root_prisoner",
      "name": "根笼囚徒",
      "position": [
        11000,
        500
      ],
      "role": "gate_hint",
      "dialogue": [
        "下劈棘球，你会被弹起来；下劈我，我会骂你，虽然也许骂得不响。",
        "根笼下方有一条回前厅的暗道，我掉进去三次才变得这么确定。",
        "园主害怕断掉的弦，因为那声音像旧王的命令，又像有人终于拒绝。"
      ],
      "identity": "被根笼困住的失败采集者，身体被温室当成警示。",
      "motive": "想被释放，或至少让主角替他证明根笼下方有暗道。",
      "help": "提示棘线下劈反弹；说明暗道；揭示园主害怕断弦声。"
    }
  ],
