  "world_story": {
    "worldview": "旧王朝建立在一口倒扣巨钟之上。巨钟压住深井黑潮，也吞掉活人的声音、誓言和未完成愿望。",
    "protagonist": {
      "codename": "缄",
      "identity": "第七签署者留下的绯线回响，能看见命线、契约线和被删掉的名字残痕。"
    },
    "core_conflict": "继续重鸣能保住城市秩序，却延续活人声音作为封印材料；切断王冠能归还声音，却可能放出黑潮。真结局需要集齐六处证词，用绯线改写契约。",
    "truth_ladder": [
      "王冠是一口倒扣巨钟。",
      "钟壁铸入过活人名字。",
      "盐白契约删掉第七签署者。",
      "六枚印记曾是六位活人守门者心脏。",
      "失败巡礼者被重编为静音军队。",
      "第七签署者把改写契约的后门藏进绯线。"
    ],
    "endings": [
      "重鸣：城市安全但名字仍在钟里。",
      "断冠：声音归还但黑潮涌出。",
      "绯线真结局：钟声只封黑潮，不再吞人声。"
    ]
  },
